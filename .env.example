# Storj (S3-compatible) configuration
STORJ_ENDPOINT=https://gateway.storjshare.io
STORJ_BUCKET=habitsync-proofs
STORJ_ACCESS_KEY=YOUR_STORJ_ACCESS_KEY
STORJ_SECRET_KEY=YOUR_STORJ_SECRET_KEY
STORJ_REGION=global

# Backend API used by Android app for signed proof uploads
SIGNED_UPLOAD_API_BASE_URL=http://10.0.2.2:8787
PORT=8787

# Firebase project settings for backend token verification (if needed)
FIREBASE_PROJECT_ID=your-firebase-project-id
GOOGLE_APPLICATION_CREDENTIALS=backend/serviceAccountKey.json
